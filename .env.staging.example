# Environment untuk Dokploy Staging
# COPY file ini ke .env di Dokploy environment variables UI
# Atau gunakan sebagai referensi untuk setup manual

APP_ENV=staging
APP_PORT=8080

# Database (gunakan environment variables dari Dokploy PostgreSQL service)
# Atau jika pakai external DB, isi dengan credentials asli
DB_HOST=<dokploy-postgres-host-or-external-db>
DB_PORT=5432
DB_USER=<db-user>
DB_PASSWORD=<db-password>
DB_NAME=<db-name>

# JWT Configuration
# PENTING: Generate secret key yang berbeda untuk staging/production!
# Gunakan: openssl rand -base64 32
JWT_ACCESS_EXPIRY=24h
JWT_SECRET=<generate-random-secret-key>

# File Upload Configuration
# PENTING: Setup volume mount di Dokploy terlebih dahulu:
#   1. Buka Volumes & Mounts
#   2. Add Volume:
#      - Volume Name: bulky-uploads
#      - Mount Path: /app/uploads
#   3. Save dan Redeploy
UPLOAD_PATH=/app/uploads
BASE_URL=https://api-staging.bulky.id

# Optional: Logging
LOG_LEVEL=info

# Forwarder.ai API
FORWARDER_API_URL=https://platform-api.forwarder.ai/fordex-sandbox
FORWARDER_CLIENT_NAME=<forwarder-client-name>
FORWARDER_USERNAME=<forwarder-username-hash>
FORWARDER_PASSWORD=<forwarder-password-hash>
